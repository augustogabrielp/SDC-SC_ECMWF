!pip install -q ecmwf-opendata cfgrib xarray matplotlib cartopy

from ecmwf.opendata import Client
import xarray as xr
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
import pandas as pd
import numpy as np

# ==========================================================
# ESCOLHAS DO USUÁRIO
# ==========================================================

# data inicial da rodada
run_date = "2026-04-27"   # pode usar 0 (hoje), -1 (ontem)
run_time = 00             # 00, 06, 12, 18 UTC

# período desejado
start_forecast = "2026-04-28 00:00"
end_forecast   = "2026-04-30 00:00"

filename = "tp_media_7dias.grib"

# ==========================================================
# DATAS / STEPS
# ==========================================================

run_dt   = pd.Timestamp(f"{run_date} {run_time:02d}:00")
start_dt = pd.Timestamp(start_forecast)
end_dt   = pd.Timestamp(end_forecast)

step_ini = int((start_dt - run_dt).total_seconds() / 3600)
step_fim = int((end_dt   - run_dt).total_seconds() / 3600)

# número de dias do período
ndias = int((end_dt - start_dt).total_seconds() / 86400)

print("STEP INICIAL:", step_ini, "h")
print("STEP FINAL  :", step_fim, "h")
print("DIAS        :", ndias)

# ==========================================================
# BAIXA ECMWF
# ==========================================================

client = Client()

client.retrieve(
    date=run_date,
    time=run_time,
    step=[step_ini, step_fim],
    stream="oper",
    type="fc",
    levtype="sfc",
    param="tp",
    target=filename
)

# ==========================================================
# ABRE DADOS
# ==========================================================

data = xr.open_dataset(filename, engine="cfgrib")
data = data.sortby("longitude")
data = data.sortby("latitude")

# ==========================================================
# ACUMULADO TOTAL (mm)
# ==========================================================

tp_total = (
    data.tp.sel(step=f"{step_fim}h") -
    data.tp.sel(step=f"{step_ini}h")
) * 1000

# ==========================================================
# MÉDIA DIÁRIA (mm/dia)
# ==========================================================

tp = tp_total / ndias

# mascara valores muito baixos
tp = tp.where(tp >= 0.1)

# ==========================================================
# FIGURA
# ==========================================================

fig = plt.figure(figsize=(10,8))
ax = plt.axes(projection=ccrs.PlateCarree())

# ==========================================================
# RECORTE (ESCOLHER UMA OPÇÃO)
# ==========================================================

# Santa Catarina
# ax.set_extent([-55.2, -47.8, -30.0, -25.5], crs=ccrs.PlateCarree())

# Brasil inteiro
# ax.set_extent([-75, -32, -35, 6], crs=ccrs.PlateCarree())

# Sul do Brasil
ax.set_extent([-58, -47, -34, -22], crs=ccrs.PlateCarree())

# ==========================================================
# MAPA BASE
# ==========================================================

ax.coastlines(resolution='10m', linewidth=1)

ax.add_feature(cfeature.BORDERS, linewidth=0.5)

ax.add_feature(
    cfeature.STATES.with_scale("10m"),
    linewidth=0.4,
    edgecolor="gray"
)

gl = ax.gridlines(draw_labels=True, linestyle='--', alpha=0.4)
gl.top_labels = False
gl.right_labels = False

# ==========================================================
# NÍVEIS (mm/dia)
# ==========================================================

levels = [1,2,3,5,7,10,15,20,25,30,35,40]

# ==========================================================
# PLOT
# ==========================================================

cf = ax.contourf(
    data.longitude,
    data.latitude,
    tp,
    levels=levels,
    cmap="turbo",
    extend="max",
    transform=ccrs.PlateCarree()
)

cbar = plt.colorbar(cf, ax=ax, shrink=0.85, pad=0.02)
cbar.set_label("mm/dia")

# ==========================================================
# TÍTULO
# ==========================================================

plt.title(
    f"ECMWF - Precipitação média diária ({ndias} dias)\n"
    f"Rodada: {run_dt:%d/%m/%Y %HUTC}\n"
    f"Período: {start_dt:%d/%m/%Y %HUTC} até {end_dt:%d/%m/%Y %HUTC}",
    fontsize=13,
    fontweight="bold"
)


# ==========================================================
# SALVAR A FIGURA
# ==========================================================
plt.savefig(
    f"{pasta}/ECMWF_precipitacao_start{start_dt:%d-%m-%Y_%HUTC}_end{end_dt:%d-%m-%Y_%HUTC}.png",
    dpi=600,
    bbox_inches="tight"
)


# ==========================================================
# PLOTAR A FIGURA
# ==========================================================

plt.show()

# ==========================================================
# ESTATÍSTICAS
# ==========================================================

print("Mínimo:", float(tp.min()), "mm/dia")
print("Máximo:", float(tp.max()), "mm/dia")
print("Média :", float(tp.mean()), "mm/dia")





